<form class="clipboard-image-destination-config flexcol" autocomplete="off">
  <div class="form-group">
    <label>Source</label>
    <div class="form-fields">
      <select name="source">
        {{selectOptions sourceChoices selected=source}}
      </select>
    </div>
    <p class="notes">Automatic follows the current host. Use Amazon S3 when you want clipboard uploads to go to a configured S3 bucket.</p>
  </div>

  <div class="form-group clipboard-image-s3-bucket{{#unless isS3}} hidden{{/unless}}">
    <label>S3 Bucket</label>
    <div class="form-fields">
      <input type="text" name="bucket" value="{{bucket}}" placeholder="my-bucket" />
    </div>
    <p class="notes">Required for Amazon S3 destinations. Choosing a folder from the file picker fills this automatically.</p>
  </div>

  <div class="form-group">
    <label>Folder</label>
    <div class="form-fields">
      <input type="text" name="target" value="{{target}}" placeholder="pasted_images" />
      <button type="button" data-action="browse-destination">
        <i class="fas fa-file-import fa-fw"></i>
      </button>
    </div>
    <p class="notes">Browse uses Foundry's native file picker so you can switch between supported file stores without re-entering the path manually.</p>
  </div>

  <div class="form-group">
    <label>Current Destination</label>
    <div class="form-fields">
      <input type="text" value="{{destinationSummary}}" data-role="destination-summary" disabled />
    </div>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit" name="submit">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>
</form>
