<form class="foundry-paste-eater-destination-config flexcol" autocomplete="off">
  <div class="form-group">
    <label>Source</label>
    <div class="form-fields">
      <select name="source">
        {{selectOptions sourceChoices selected=source}}
      </select>
    </div>
    <p class="notes">Automatic follows the current host. Use S3-compatible storage when Foundry is configured to upload through Amazon S3, Cloudflare R2, MinIO, or another compatible provider.</p>
  </div>

  <div class="form-group foundry-paste-eater-s3-bucket{{#unless isS3}} hidden{{/unless}}">
    <label>Bucket</label>
    <div class="form-fields">
      <input type="text" name="bucket" value="{{bucket}}" placeholder="my-bucket" />
    </div>
    <p class="notes">Required for S3-compatible destinations. Choosing a folder from the file picker fills this automatically.</p>
  </div>

  <div class="form-group foundry-paste-eater-s3-endpoint{{#unless isS3}} hidden{{/unless}}">
    <label>Endpoint / Base URL</label>
    <div class="form-fields">
      <input type="text" value="{{s3Endpoint}}" data-role="s3-endpoint" placeholder="Configured by Foundry server storage settings" disabled />
    </div>
    <p class="notes">This comes from Foundry's server-side S3 configuration. If you use Cloudflare R2 or another S3-compatible provider, change the endpoint there rather than in this module.</p>
  </div>

  <div class="form-group">
    <label>Folder</label>
    <div class="form-fields">
      <input type="text" name="target" value="{{target}}" placeholder="pasted_images" />
      <button type="button" data-action="browse-destination">
        <i class="fas fa-file-import fa-fw"></i>
      </button>
    </div>
    <p class="notes">Browse uses Foundry's native file picker so you can switch between supported file stores without re-entering the path manually.</p>
  </div>

  <div class="form-group">
    <label>Current Destination</label>
    <div class="form-fields">
      <input type="text" value="{{destinationSummary}}" data-role="destination-summary" disabled />
    </div>
  </div>

  <footer class="sheet-footer flexrow">
    <button type="submit" name="submit">
      <i class="fas fa-save"></i> Save
    </button>
  </footer>
</form>
